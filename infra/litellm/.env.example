# econ-litellm gateway — operator env template.
# Copy to .env.local (gitignored) and fill in real values. .env.local is only
# used by local tooling (probe.sh, curl smokes, tools/*-cost scripts); the
# RUNTIME secrets live on the fly app itself and are managed with
# `fly secrets set/unset -a econ-litellm`:
#
#   LITELLM_MASTER_KEY        gateway auth (same value as below)
#   FIREWORKS_API_KEY         provider BYOK key
#   DATABASE_URL              postgres-flex econ-litellm-db, database econ_litellm
#   <TIER>_DEPLOYMENT_PATH    optional dedicated-GPU flips — set/unset ONLY via
#                             e2e/distributed/gpu-flip.sh (see DEDICATED-FLIP.md)
#
LITELLM_MASTER_KEY=sk-econ-REPLACE_ME
